{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @nutcrack/ai build && pnpm --filter @nutcrack/scrape build && pnpm --filter @nutcrack/shared build && tsc",
    "build:workspace": "tsc",
    "start": "node dist/index.js",
    "test": "pnpm --filter @nutcrack/ai build && pnpm --filter @nutcrack/scrape build && vitest run",
    "test:watch": "vitest",
    "check": "pnpm --filter @nutcrack/ai build && pnpm --filter @nutcrack/scrape build && tsc --noEmit",
    "fmt": "prettier --write \"src/**/*.{ts,json}\""
  },
  "dependencies": {
    "@nutcrack/ai": "workspace:*",
    "@nutcrack/db": "workspace:*",
    "@nutcrack/scrape": "workspace:*",
    "@nutcrack/shared": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.7.6",
    "@mozilla/readability": "^0.5.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "jsdom": "^25.0.0",
    "turndown": "^7.2.1",
    "turndown-plugin-gfm": "^1.0.2",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsdom": "^21.1.0",
    "@types/node": "^25.3.5",
    "@types/uuid": "^10.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
