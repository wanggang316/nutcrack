{
  "name": "@nutcrack/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "fmt": "prettier --write \"src/**/*.{ts,json}\"",
    "generate": "drizzle-kit generate",
    "migrate:run": "tsx src/migrate.ts"
  },
  "files": [
    "dist",
    "migrations"
  ],
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.5.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0"
  }
}
