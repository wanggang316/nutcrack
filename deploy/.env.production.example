# Nutcrack production environment — REFERENCE TEMPLATE ONLY.
#
# The authoritative values live in the central project-env repo at
# nutcrack/prod/env (git-crypt encrypted). On every deploy, activate.sh runs
#   project-env-install nutcrack prod /opt/nutcrack/shared/.env
# which overwrites the on-VM .env. Do NOT hand-edit /opt/nutcrack/shared/.env —
# changes are lost on the next deploy and bypass review. To change a value,
# open a PR against project-env (see deploy/README.md).
#
# This file only documents the expected keys. Loaded by systemd via
# EnvironmentFile=. Parsing rules:
#   - no quotes around values
#   - no inline comments after a value

NODE_ENV=production
DATABASE_URL=/opt/nutcrack/shared/data/nutcrack.db

# API server — must be distinct from other apps on the VM (inboxlm uses 3000)
PORT=3010
CORS_ORIGIN=https://nutcrack.gumpw.com

# Logging
LOG_LEVEL=info

# ---------- optional external services ----------
# Jina Reader API key for link scraping. Without it, link processing will
# fail at the fetch step. AI keys live in the in-app settings table.
JINA_API_KEY=__YOUR_JINA_KEY__
