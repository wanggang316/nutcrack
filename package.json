{
  "name": "nutcrack",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --parallel --filter api --filter web run dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:extension": "pnpm --filter extension dev",
    "dev:cli": "pnpm --filter ./cli dev",
    "build:cli": "pnpm --filter ./cli build",
    "pack:cli": "pnpm --filter ./cli run pack:local",
    "publish:cli": "pnpm --filter ./cli publish",
    "build": "pnpm --filter @nutcrack/db build && pnpm --filter @nutcrack/shared build && pnpm --filter @nutcrack/ai build && pnpm --filter @nutcrack/scrape build && pnpm --filter api run build:workspace && pnpm --parallel --filter web --filter extension --filter ./cli build",
    "test": "pnpm --parallel test",
    "test:api": "pnpm --filter api test"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@nutcrack/db": "workspace:*",
    "@types/node": "^25.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
